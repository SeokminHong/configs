{
  "name": "@seokminhong/configs",
  "version": "2.4.0",
  "type": "module",
  "description": "All-in-one ESLint, TypeScript, and Prettier configurations",
  "main": "index.js",
  "exports": {
    "./eslint": {
      "default": "./eslint/index.js"
    },
    "./eslint/*": {
      "default": "./eslint/extensions/*.js"
    },
    "./prettier": {
      "default": "./prettier.js"
    },
    "./tsconfig/*": {
      "default": "./tsconfig/*.json"
    }
  },
  "files": [
    "tsconfig",
    "eslint",
    "prettier.js",
    "prettier-plugins",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "eslint",
    "typescript",
    "tsconfig",
    "prettier",
    "configs"
  ],
  "author": "Seokmin Hong <ghdtjrald240@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/SeokminHong/configs"
  },
  "license": "MIT",
  "dependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.0",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "eslint-plugin-storybook": "10.1.10",
    "eslint-plugin-unicorn": "62.0.0",
    "globals": "16.5.0",
    "typescript-eslint": "8.50.0"
  },
  "peerDependencies": {
    "eslint": ">=9.27.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    },
    "prettier": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24",
    "eslint": "9.39.2"
  },
  "packageManager": "pnpm@9.15.3"
}
