{
  "name": "@seokminhong/configs",
  "version": "3.0.0",
  "type": "module",
  "description": "All-in-one ESLint, TypeScript, and Prettier configurations",
  "main": "index.js",
  "exports": {
    "./eslint": {
      "default": "./eslint/index.js"
    },
    "./eslint/*": {
      "default": "./eslint/extensions/*.js"
    },
    "./prettier": {
      "default": "./prettier.js"
    },
    "./tsconfig/*": {
      "default": "./tsconfig/*.json"
    }
  },
  "files": [
    "tsconfig",
    "eslint",
    "prettier.js",
    "prettier-plugins",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "eslint",
    "typescript",
    "tsconfig",
    "prettier",
    "configs"
  ],
  "author": "Seokmin Hong <ghdtjrald240@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeokminHong/configs.git"
  },
  "license": "MIT",
  "dependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-storybook": "10.4.0",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.6.0",
    "typescript-eslint": "8.59.4"
  },
  "peerDependencies": {
    "eslint": ">=9.27.0 <11",
    "prettier": "^3.8.3",
    "typescript": ">=6.0.3 <6.1.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    },
    "prettier": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "eslint": "10.4.0"
  },
  "packageManager": "pnpm@9.15.3"
}
